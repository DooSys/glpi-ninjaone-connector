msgstr "Échec de la connexion NinjaOne : "

msgid "NinjaOne synchronization finished: %d created, %d updated, %d skipped, %d errors."
msgstr "Synchronisation NinjaOne terminée : %d créé(s), %d mis à jour, %d ignoré(s), %d erreur(s)."

