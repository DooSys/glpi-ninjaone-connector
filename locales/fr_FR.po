msgid "Leave the repeat field empty to run once per day at the configured time."
msgstr "Laissez la répétition vide pour exécuter la synchronisation une fois par jour à l'heure configurée."

msgid "The GLPI automatic action runs the NinjaOne synchronization twice a day. Use the button below to force an immediate synchronization when needed."
msgstr "L'action automatique GLPI exécute la synchronisation NinjaOne deux fois par jour. Utilisez le bouton ci-dessous pour forcer une synchronisation immédiate si besoin."

msgid "Synchronize NinjaOne inventory twice a day"
msgstr "Synchroniser l'inventaire NinjaOne deux fois par jour"

